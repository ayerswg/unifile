    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.15",
    "@lezer/highlight": "^1.2.3",
    "@marp-team/marp-core": "^4.3.0",
    "abcjs": "^6.0.0",
    "docx": "^8.5.0",
    "dompurify": "^3.0.0",
