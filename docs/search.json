---
layout: none
---
{% assign all = site.pages | concat: site.posts %}
[
{% assign first = true %}
{% for item in all %}{% if item.title and item.title != "" %}{% unless first %},{% endunless %}{% assign first = false %}
{
"title": {{ item.title | jsonify }},
"url": {{ item.url | jsonify }},
"excerpt": {{ item.excerpt | strip_html | truncate: 120 | jsonify }},
"date": {% if item.date %}{{ item.date | date: "%B %d, %Y" | jsonify }}{% else %}null{% endif %},
"type": {% if item.date %}"post"{% else %}"page"{% endif %},
"pinned": {% if item.pinned %}true{% else %}false{% endif %}
}{% endif %}{% endfor %}
{% for app in site.data.apps %}{% unless first %},{% endunless %}{% assign first = false %}
{
"title": {{ app.title | jsonify }},
"url": {{ app.url | jsonify }},
"excerpt": {{ app.excerpt | default: "" | jsonify }},
"date": null,
"type": {{ app.kind | default: "app" | jsonify }},
"pinned": {% if app.pinned %}true{% else %}false{% endif %}
}{% endfor %}
]
